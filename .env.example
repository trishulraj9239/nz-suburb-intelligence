# Copy to .env.local and fill in. Also set these in Vercel → Project → Settings → Environment Variables.
# Only NEXT_PUBLIC_-prefixed vars reach the browser. Never add server-only secrets
# (Supabase service-role key, ANTHROPIC_API_KEY, GEMINI_API_KEY) with a NEXT_PUBLIC_ prefix.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# LINZ scoped WMTS tile key — wired now, not used until tiles land (later milestone)
NEXT_PUBLIC_LINZ_API_KEY=
